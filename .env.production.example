# =============================================================================
# Pflanzenulli Production Environment
# Copy this to .env.production and fill in real values
# =============================================================================

# --- Database (internal Docker network: use service name "postgres") ---
DATABASE_URL=postgresql://pflanzenulli:CHANGE_ME_DB_PASSWORD@postgres:5432/pflanzenulli
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# --- Redis (internal Docker network: use service name "redis") ---
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- Meilisearch (internal Docker network: use service name "meilisearch") ---
MEILISEARCH_URL=http://meilisearch:7700
MEILI_MASTER_KEY=CHANGE_ME_MEILI_KEY

# --- Minio (internal Docker network: use service name "minio") ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=pflanzenulli
MINIO_USE_SSL=false

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_AUTH_SECRET
AUTH_URL=https://your-domain.eu

# --- OAuth Providers ---
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=Pflanzenulli <noreply@your-domain.eu>

# --- Subscription billing (Paddle) ---
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=https://your-domain.eu
NODE_ENV=production

# --- Feature flags ---
EARLY_ACCESS_ENABLED=true
